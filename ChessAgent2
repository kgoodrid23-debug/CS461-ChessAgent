    for x in range(0,8):
        for y in range(1,9): 
            xpos = 62.5 * x
            ypos = 62.5*(8-y)
            if color_bool: color_bool = False; color_string = "tan"
            else: color_bool = True; color_string = "gray"        
            pygame.draw.rect(screen, color_string, [xpos, ypos, 63, 63])
        if color_bool: color_bool = False; color_string = "tan"
        else: color_bool = True; color_string = "gray"

