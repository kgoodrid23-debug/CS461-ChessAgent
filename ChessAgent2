def set_check(screen):
    font = pygame.font.SysFont('Arial', 100)
    text_surface = font.render('CHECK!', True, "Black")
    text_surface.set_alpha(10)
    screen.blit(text_surface, (100, 200))
def run_game(running, clock, board: chess.Board, player_color, move_history, agent, screen):
    while running:
        if board.is_game_over(): running = not running
        for event in pygame.event.get():# poll for events
            if event.type == pygame.QUIT: running = False# pygame.QUIT event means the user clicked X to close your window
            if event.type == pygame.KEYDOWN:#undo button (instead of typing)
                if event.key == pygame.K_SPACE:
                    raw = 'undo'
                    if raw.lower() == 'undo':
                        if len(move_history) >= 2:
                            board.pop(); board.pop()
                            move_history = move_history[:-2]
                            print("  Last two moves undone.")
                            set_game_visuals(screen,board)
                            if board.is_check(): set_check(screen)
                        else:
                            print("  Nothing to undo.")
                        continue
                    # Re-use get_player_move logic inline
                    try:
                        try:
                            move = chess.Move.from_uci(raw)
                            if move not in board.legal_moves:
                                raise ValueError("Illegal")
                        except ValueError:
                            move = board.parse_san(raw)
                    except Exception as e:
                        print(f"  Invalid move: {e}\n")
                        continue

        # RENDER YOUR GAME HERE
            if event.type == pygame.MOUSEBUTTONDOWN:
                mpos = pygame.mouse.get_pos()
                x,y = mpos[0],mpos[1]
                if x >= 0 and x <= 500: row = math.floor(x/63)
                if y >= 0 and y <= 500: col = math.floor(y/63)
                if inputs[0][0] == None:
                    inputs[0][0],inputs[0][1] = col,row
                    yellow_alpha = (255, 255, 0, 128)#Highlight choice color
                    rect_surface = pygame.Surface((63, 63), pygame.SRCALPHA)# Highlight color square
                    rect_surface.fill(yellow_alpha)# Highlight color's color fill
                    screen.blit(rect_surface, (row*62.5,col*62.5))#Display Highlighted color square on screen
                elif inputs[0][0] == col and inputs[0][1] == row:
                    inputs[0][0],inputs[0][1] = None,None
                    set_game_visuals(screen,board)
                elif inputs[1][0] == None:
                    inputs[1][0],inputs[1][1] = col,row
                    #This check the first inputs is a piece and the second input check for valid positions
                    if arrr[inputs[0][0]][inputs[0][1]] == "P":
                        if arrr[inputs[1][0]][inputs[1][1]] == ".":#empty space as a pawn = ex)f4
                            num,letter = inputs[1][0],inputs[1][1]
                            concat = str(alphabet[letter])+str(8-num)
                        else:#taking piece as a pawn = ex)exf4
                            num,letter = inputs[1][0],inputs[1][1]
                            concat = str(alphabet[inputs[0][1]])+"x"+str(alphabet[letter])+str(8-num)
                    else:#for every other piece [Rook, Knight, Bishop, Queen, King]
                        moving_piece = arrr[inputs[0][0]][inputs[0][1]]
                        num,letter = inputs[1][0],inputs[1][1]
                        if arrr[inputs[1][0]][inputs[1][1]] == ".":concat = moving_piece+str(alphabet[letter])+str(8-num)
                        else:concat = moving_piece+"x"+str(alphabet[letter])+str(8-num)
                    inputs[0][0],inputs[0][1],inputs[1][0],inputs[1][1] = None,None,None,None
                    set_game_visuals(screen,board)
                    #-----------------------------------------
                    status = []
                    if board.is_check(): status.append("  CHECK!")
                    turn_name = "White" if board.turn == chess.WHITE else "Black"
                    who = "You" if board.turn == player_color else "AI"
                    print(f"  Turn {board.fullmove_number} — {turn_name} to move ({who})")
                    if status: print("  " + " | ".join(status))
            
                    if board.turn == player_color:# Player's turn
                        raw = concat
                        try:
                            try:
                                move = chess.Move.from_uci(raw)
                                if move not in board.legal_moves:
                                    raise ValueError("Illegal")
                            except ValueError:
                                move = board.parse_san(raw)
                        except Exception as e:
                            print(f"  Invalid move: {e}\n")
                            continue
            
                        board.push(move)
                        move_history.append(move)
                        print(f"  You played: {move.uci()}\n")

                    if board.turn != player_color and running:
                        # AI's turn
                        print("  AI is thinking...", end="", flush=True)
                        t0 = time.time()
                        ai_move = agent.choose_move(board)
                        elapsed = time.time() - t0
            
                        if ai_move is None:break
            
                        san = board.san(ai_move)
                        board.push(ai_move)
                        move_history.append(ai_move)
                        print(f"\r  AI played: {san} ({elapsed:.2f}s, {agent.nodes_searched} nodes)\n")

                    set_game_visuals(screen,board)
                    if board.is_check(): set_check(screen)
                    #-----------------------------------------
                elif inputs[1][0] == col and inputs[1][1] == row: inputs[1][0],inputs[1][1] = None,None
        pygame.display.flip()# flip() the display to put your work on screen

        clock.tick(60)  # limits FPS to 60
    pygame.quit()

